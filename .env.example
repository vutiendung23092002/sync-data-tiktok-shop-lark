# Required: no implicit production default.
SYNC_ENV=test
FROM=2026/07/01
TO=2026/07/15
DRY_RUN=true
LOG_LEVEL=info

# Comma-separated TikTok Shop IDs. For every ID, define the two dynamic keys below.
TIKTOK_SHOP_IDS=<han_korea_shop_id>
TIKTOK_PARTNER_APP_KEY_<han_korea_shop_id>=<tiktok_partner_app_key>
TIKTOK_PARTNER_APP_SECRET_<han_korea_shop_id>=<tiktok_partner_app_secret>

# Single-shop alternative supported by the current deployment:
# TIKTOK_SHOP_ID=<han_korea_shop_id>
# TIKTOK_PARTNER_APP_KEY=<tiktok_partner_app_key>
# TIKTOK_PARTNER_APP_SECRET=<tiktok_partner_app_secret>

LARK_APP_ID=<lark_app_id>
LARK_APP_SECRET=<lark_app_secret>
LARK_BATCH_SIZE=500

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require

# Exactly 32 UTF-8 bytes. hex: and base64: forms are also supported.
AES_256_CBC_APP_SECRET_KEY=<32_character_fixed_key>
